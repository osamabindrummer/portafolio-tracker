# Variables para desarrollo local o para documentar la configuración remota.

# Usa "local" para escribir en archivos del repositorio durante desarrollo.
PORTFOLIO_STORAGE=local

# Token de lectura/escritura de Vercel Blob.
BLOB_READ_WRITE_TOKEN=

# Enfriamiento mínimo entre refresh públicos para evitar abuso.
REFRESH_COOLDOWN_SECONDS=600

# Se usa sólo para proteger el endpoint llamado por Vercel Cron.
CRON_SECRET=
