{
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "includeFiles": "public/indicators/latest.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/refresh-data",
      "destination": "/api/refresh_data"
    },
    {
      "source": "/api/refresh-indicators",
      "destination": "/api/refresh_indicators"
    },
    {
      "source": "/api/refresh-all",
      "destination": "/api/refresh_all"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh",
      "schedule": "0 9 * * 1,3,5"
    }
  ]
}
